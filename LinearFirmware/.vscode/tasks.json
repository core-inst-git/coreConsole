{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[Linear] CubeIDE: Build Release (ELF)",
      "type": "shell",
      "command": "/Applications/STM32CubeIDE.app/Contents/MacOS/STM32CubeIDE",
      "args": [
        "-nosplash",
        "-application",
        "org.eclipse.cdt.managedbuilder.core.headlessbuild",
        "-data",
        "/tmp/cubeide-workspace",
        "-import",
        "${workspaceFolder}",
        "-build",
        "coreDAQ_firmware_LINEAR_v1.0/Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "[Linear] Objcopy: Release (BIN)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "arm-none-eabi-objcopy -O binary Release/coreDAQ_firmware_LINEAR_v1.0.elf Release/coreDAQ_firmware_LINEAR_v1.0.bin"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "[Linear] Build Release (ELF+BIN)",
      "dependsOn": [
        "[Linear] CubeIDE: Build Release (ELF)",
        "[Linear] Objcopy: Release (BIN)"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "coreDAQ: Enter DFU",
      "type": "shell",
      "command": "python3",
      "args": [
        "${workspaceFolder}/API/enter_dfu.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
