{
  "name": "coreconsole-root",
  "private": true,
  "engines": {
    "node": "^20.0.0",
    "npm": "^10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "predev": "npm run visa:addon:check",
    "dev": "npm --prefix GUI run dev",
    "build": "npm --prefix GUI run build",
    "dist": "npm --prefix GUI run dist",
    "dist:mac": "npm --prefix GUI run dist:mac",
    "dist:win": "npm --prefix GUI run dist:win",
    "dist:win:portable": "npm --prefix GUI run dist:win:portable",
    "dist:win:zip": "npm --prefix GUI run dist:win:zip",
    "release:organize": "npm --prefix GUI run release:organize",
    "visa:addon:install": "npm --prefix packages/visa-addon install",
    "visa:addon:build": "npm --prefix packages/visa-addon run build",
    "visa:addon:check": "node -e \"const fs=require('fs'); const p='packages/visa-addon/build/Release/visa_addon.node'; if(!fs.existsSync(p)){console.error('[coreConsole] missing '+p+'. Run bootstrap or npm run visa:addon:build.'); process.exit(1);} console.log('[coreConsole] visa addon OK: '+p);\"",
    "visa:service:check": "npm --prefix packages/visa-service run check",
    "visa:service:demo": "npm --prefix packages/visa-service run demo",
    "visa:smoke": "npm --prefix packages/visa-service run smoke",
    "visa:smoke:mock": "npm --prefix packages/visa-service run smoke:mock"
  }
}
